# Talent OS — Backend environment template.
# Copy to .env and fill in real values. Never commit the real .env.

# ── Database ──────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=recruitment_db
POSTGRES_USER=talentos_write
POSTGRES_PASSWORD=

# ── Redis / Celery (only used if the celery-worker/celery-beat services
#    from talent-os/docker-compose.yml are actually deployed -- they are
#    NOT part of the current production stack) ─────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_CONCURRENCY=2

# ── Internal API key (X-API-Key header on /api/candidates, /api/jobs,
#    /api/matches, /api/apollo) ─────────────────────────────────────────────
API_KEY=

# ── OpenRouter (all LLM calls go through this, no models hosted locally) ───
OPENROUTER_API_KEY=

# ── Apollo.io (candidate/company sourcing) ─────────────────────────────────
APOLLO_API_KEY=

# ── SMTP (currently unused -- email actually sends via Gmail API/OAuth
#    below, not SMTP; kept for config compatibility) ───────────────────────
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── Google OAuth (Gmail API, for transactional email sending) ──────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Backend ─────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=4
LOG_LEVEL=INFO

# ── CORS (comma-separated, no wildcards) ───────────────────────────────────
CORS_ORIGINS=https://gsprecruitment.nl,https://www.gsprecruitment.nl

# ── Auth ─────────────────────────────────────────────────────────────────
# jwt_secret must be at least 32 random characters -- app refuses to start
# below that length or at the placeholder default (see core/config.py).
JWT_SECRET=
WEBHOOK_SECRET=
